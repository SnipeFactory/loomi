{
  "name": "loomi",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n server,next -c blue,green \"NODE_OPTIONS='--max-old-space-size=6144 --expose-gc' tsx watch backend.ts\" \"LOOMI_BACKEND_URL=http://localhost:2001 NODE_OPTIONS='--max-old-space-size=6144' next dev -p 2000\"",
    "dev:server": "NODE_OPTIONS='--max-old-space-size=6144 --expose-gc' tsx watch backend.ts",
    "dev:ui": "LOOMI_BACKEND_URL=http://localhost:2001 NODE_OPTIONS='--max-old-space-size=6144' next dev -p 2000",
    "dev:clean": "fuser -k 2000/tcp 2>/dev/null; fuser -k 2001/tcp 2>/dev/null; npm run dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start:server": "NODE_ENV=production NODE_OPTIONS='--max-old-space-size=4096 --expose-gc' tsx backend.ts",
    "start:ui": "NODE_ENV=production LOOMI_BACKEND_URL=http://localhost:2001 NODE_OPTIONS='--max-old-space-size=4096' next start -p 2000",
    "start": "concurrently -n server,next -c blue,green \"npm:start:server\" \"npm:start:ui\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "mcp-server": "NODE_OPTIONS='--max-old-space-size=4096' tsx src/mcp-server.ts",
    "benchmark": "NODE_OPTIONS='--max-old-space-size=4096 --expose-gc' tsx scripts/benchmark.ts",
    "demo:seed": "tsx scripts/seed-demo.ts",
    "demo:rollback": "tsx scripts/rollback-demo.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xenova/transformers": "^2.17.2",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "franc": "^6.2.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  }
}
